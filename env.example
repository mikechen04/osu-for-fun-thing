# recommended: oauth app from https://osu.ppy.sh/home/account/edit#oauth
# create an app, use "client credentials" / public scope — lets us read public profiles, bio (page), and best scores
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# optional fallback: legacy key from https://osu.ppy.sh/p/api — stats + top plays only, no profile description text
OSU_API_KEY=

PORT=3000
